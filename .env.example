NCBI_EMAIL=you@example.com
NCBI_API_KEY=
NCBI_TOOL=retarats_pubmed_pipeline_v2
NCBI_MAX_RPS=

# Contact email for the "polite pool" of keyless APIs (OpenAlex, Crossref,
# Unpaywall). No key needed for OpenAlex/Crossref; Unpaywall just wants this email.
API_CONTACT_EMAIL=you@example.com
# Copy this file to `.env` (which is gitignored) and fill in your values.
# NEVER commit real keys. For GitHub Actions, add NCBI_API_KEY / NCBI_EMAIL as
# repo secrets (Settings -> Secrets and variables -> Actions), not in any file.

# Shared config. v2 usually uses inputs; original retarats.py uses local/google.
CONFIG_MODE=inputs
LOCAL_CONFIG_DIR=config
CONFIG_SHEET_NAME=Moleculessearch
INPUT_WORKBOOK=inputs/Moleculessearch.xlsx
SUMMARY_WORKBOOK=inputs/Summary Sheet.xlsx

# v2 run settings.
V2_RUN_MODE=daily
V2_DEFAULT_DAILY_DAYS=7
V2_DEFAULT_START_YEAR=2000
NCBI_DATETYPE=pdat

SUMMARY_MODE=rule_based
ROLE_RULES=config/ROLE_RULES.csv

OUTPUT_SINKS=local
LOCAL_DB=data/retarats_pubmed.sqlite
STATE_DB=data/retarats_state.sqlite
OUTPUT_GOOGLE_SHEET=RetaRats_PubMed_v2

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_MOLECULES_TABLE=Molecules
AIRTABLE_PAPERS_TABLE=Papers
AIRTABLE_EVIDENCE_TABLE=Evidence
AIRTABLE_PROFILES_TABLE=MoleculeProfiles

# Original retarats.py Google Drive output settings.
RUN_MODE=AUTO
DEFAULT_DAILY_DAYS=1
DEFAULT_START_YEAR=2000
DRIVE_FOLDER_PATH=My Drive/Retarats
OUTPUT_BASE_NAME=RetaRats_PubMed
